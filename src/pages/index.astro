---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Navbar from "../components/Navbar.astro";
import AboutSection from "../components/AboutSection.astro";
import ExperienceSection from "../components/ExperienceSection.astro";
import TechSection from "../components/TechSection.astro";
import ThoughtsSection from "../components/ThoughtsSection.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Gonzalo Cubilla - Portfolio">
	<main class="min-h-screen bg-background relative scanlines">
		<Header />
		<div class="max-w-4xl mx-auto px-4 w-full">
			<Navbar />
			<AboutSection />
			<ExperienceSection />
			<TechSection />
			<ThoughtsSection />
			<ProjectsSection />
			<Footer />
		</div>
	</main>
</Layout>
