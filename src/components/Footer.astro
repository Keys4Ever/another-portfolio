            <div class="space-y-2 text-sm">
                <p class="text-foreground/70">
                    &gt; Feel free to reach out for collaborations or just to
                    say hi.
                </p>
                <a
                    href="mailto:cubillagonzalo@outlook.com"
                    class="inline-block text-primary hover:underline transition-all duration-300"
                >
                    [cubillagonzalo@outlook.com]
                </a>
            </div>
