---
const { title } = Astro.props;
---

<div
    class="relative overflow-hidden border border-zinc-700 bg-zinc-950 text-zinc-200 font-mono"
>
    <!-- Scanlines overlay -->
    <div
        class="pointer-events-none absolute inset-0 opacity-[0.08] bg-[linear-gradient(rgba(255,255,255,0.08)_1px,transparent_1px)] bg-[size:100%_3px]"
    >
    </div>

    <!-- Title bar -->
    <div
        class="border-b border-zinc-700 bg-zinc-900 px-4 py-2 text-xs font-ank uppercase tracking-widest text-zinc-400"
    >
        &gt; {title}
    </div>

    <div class="relative px-4 py-4 text-sm leading-relaxed">
        <slot />
    </div>
</div>
